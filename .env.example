# Required: local path or git URL for central context registry
CONTEXT_REGISTRY=/path/to/context-registry

# Optional: directory inside the registry root/repo containing projects/ and layers/
REGISTRY_DIR=contexts

# Optional: token/key for private HTTPS git registry
# - if value contains ':', it is treated as Basic auth pair (username:password)
# - otherwise treated as a token for HTTPS git authentication
REGISTRY_KEY=

# Optional: read private registry token/key from a file
# REGISTRY_KEY_FILE=./local-data/registry-key

# Optional: cache TTL in seconds (default: 300)
CACHE_EXPIRY=300

# Optional transport settings (default stdio)
# MCP_TRANSPORT=stdio
# or
# MCP_TRANSPORT=httpStream
PORT=8080
HOST=0.0.0.0

# Optional OAuth auth for MCP access
# Set OAUTH_AUTH_ENDPOINT=NONE to disable OAuth explicitly.
# OAUTH_AUTH_ENDPOINT=https://auth.example.com/oauth/authorize
# OAUTH_BASE_URL=https://mcp.example.com
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_TOKEN_ENDPOINT=https://auth.example.com/oauth/token
# OAUTH_SCOPES=openid profile

# Optional fixed API key auth for MCP access
# ACCESS_API_KEY=replace-me

# Optional debug mode for resolve_context traces
# 1 enables append-only debug logs
DEBUG_MCP=0

# Optional custom file path (default: ./data/output.log)
DEBUG_MCP_OUTPUT=./output.log
